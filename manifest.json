{
    "manifest_version": 3,
    "name": "EnvAware",
    "short_name": "EnvAware",
    "version": "1.0.0",
    "description": "Instantly identify your environment with customizable watermark overlays. Supports wildcards, per-site configs, presets, and live preview — no page reload needed.",
    "homepage_url": "https://github.com/corentinbjr/EnvAware",
    "permissions": [
        "storage",
        "activeTab",
        "scripting"
    ],
    "action": {
        "default_popup": "popup.html",
        "default_icon": {
            "16": "icons/icon-16.png",
            "48": "icons/icon-48.png",
            "128": "icons/icon-128.png"
        }
    },
    "options_page": "options.html",
    "icons": {
        "16": "icons/icon-16.png",
        "48": "icons/icon-48.png",
        "128": "icons/icon-128.png"
    },
    "content_scripts": [
        {
            "matches": [
                "<all_urls>"
            ],
            "js": [
                "js/core.js",
                "content.js"
            ],
            "run_at": "document_end"
        }
    ]
}