{
  "git": {
    "commitMessage": "release v${version}",
    "tagName": "v${version}",
    "tagAnnotation": "v${version}"
  },
  "npm": false,
  "github": {
    "release": true,
    "releaseName": "v${version}",
    "assets": ["envaware-v${version}.zip"]
  },
  "hooks": {
    "after:bump": "node scripts/sync-version.js ${version} && git add manifest.json package.json && npm run zip",
    "after:release": "echo 'Released v${version}'"
  }
}
